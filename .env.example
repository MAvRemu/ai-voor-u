# OpenClaw Multi-Customer Environment Variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# Generated by deploy/generate.sh — do not edit manually

# --- Google Workspace OAuth ---
GWS_CLIENT_ID=               # Google OAuth client ID
GWS_CLIENT_SECRET=           # Google OAuth client secret

# --- Shared API Keys ---
OPENROUTER_API_KEY=
GOOGLE_MAPS_API_KEY=
SERPAPI_KEY=
XAI_API_KEY=

# --- Customer base ---
CUSTOMER_BASE_TOKEN=          # Generate with: openssl rand -hex 32
CUSTOMER_BASE_ANTHROPIC_KEY=  # sk-ant-... (optional)
CUSTOMER_BASE_OPENAI_KEY=     # sk-... (optional)

# --- Customer 3 ---
CUSTOMER_3_TOKEN=          # Generate with: openssl rand -hex 32
CUSTOMER_3_ANTHROPIC_KEY=  # sk-ant-... (optional)
CUSTOMER_3_OPENAI_KEY=     # sk-... (optional)

# --- marius-van-remundt ---
MARIUS_VAN_REMUNDT_TOKEN=          # Generate with: openssl rand -hex 32
MARIUS_VAN_REMUNDT_ANTHROPIC_KEY=  # sk-ant-... (optional)
MARIUS_VAN_REMUNDT_OPENAI_KEY=     # sk-... (optional)
